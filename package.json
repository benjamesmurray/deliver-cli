{
  "name": "@epoch-ai/deliver-cli",
  "version": "3.0.0",
  "description": "Streamlined MCP server for managing spec workflow (requirements, design, implementation)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "deliver-cli": "dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "api/**/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsc && chmod 755 dist/index.js dist/cli.js && ./scripts/sync-package.sh",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "debug": "./debug.sh",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "generate:types": "tsx scripts/generateTypes.ts",
    "generate:webui": "tsx scripts/generateOpenApiWebUI.ts",
    "sync:package": "./scripts/sync-package.sh",
    "publish": "./scripts/publish-npm.sh"
  },
  "keywords": [
    "mcp",
    "workflow",
    "spec"
  ],
  "author": "benjamesmurray",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benjamesmurray/deliver-cli.git"
  },
  "bugs": {
    "url": "https://github.com/benjamesmurray/deliver-cli/issues"
  },
  "homepage": "https://github.com/benjamesmurray/deliver-cli#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.16.0",
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^4.1.0",
    "marked": "^17.0.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/marked": "^5.0.2",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.2"
  }
}
